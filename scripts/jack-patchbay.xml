<!DOCTYPE patchbay>
<patchbay name="jack-patchbay" version="1.0.5">
 <output-sockets>
  <socket client="system" exclusive="off" name="system 1" type="jack-audio">
   <plug>capture_1</plug>
   <plug>capture_2</plug>
  </socket>
  <socket client="DIH\-STORTION" exclusive="off" name="DIH\-STORTION 1" type="jack-audio">
   <plug>audio_out_1</plug>
   <plug>audio_out_2</plug>
  </socket>
 </output-sockets>
 <input-sockets>
  <socket client="DIH\-STORTION" exclusive="off" name="DIH\-STORTION 1" type="jack-audio">
   <plug>audio_in_1</plug>
   <plug>audio_in_2</plug>
  </socket>
  <socket client="system" exclusive="off" name="system 1" type="jack-audio">
   <plug>playback_1</plug>
   <plug>playback_2</plug>
  </socket>
 </input-sockets>
 <slots/>
 <cables>
  <cable input="DIH\-STORTION 1" output="system 1" type="jack-audio"/>
  <cable input="system 1" output="DIH\-STORTION 1" type="jack-audio"/>
 </cables>
</patchbay>

